# Puerto del backend
PORT=3001

# URL de la base de datos local
DATABASE_URL="file:./dev.db"

# Credenciales de Administrador (Generar el HASH con: node scripts/hash-password.js "password")
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH="$2a$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
ADMIN_DISPLAY_NAME="ROSÉ Admin"

# Seguridad JWT
JWT_SECRET="tu-super-secreto-para-firmar-jwt-cambialo-en-produccion"
JWT_EXPIRES_IN=8h

# URLs del Frontend y API
CORS_ORIGIN=http://localhost:3001
VITE_API_URL=http://localhost:3001/api

# Portal de Cliente (Solo para desarrollo)
PORTAL_TOKEN_DEV_RETURN=false

# WhatsApp Cloud API — Patch 03A
WHATSAPP_PROVIDER=mock
WHATSAPP_SEND_ENABLED=false
WHATSAPP_SEND_MODE=test

WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# En modo test, todos los mensajes se fuerzan a este número
WHATSAPP_DEV_RECIPIENT_PHONE=

# Debe ser la URL del frontend; para pruebas móviles usar ngrok
CLIENT_ORIGIN=http://localhost:3001

# Webhooks opcionales para futuros patches
WHATSAPP_WEBHOOK_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
